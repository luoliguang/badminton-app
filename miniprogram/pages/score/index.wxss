.page {
  min-height: 100vh;
  background: #040918;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.bg-grid {
  position: absolute;
  inset: 0;
  background-size: 40rpx 40rpx;
  background-image:
    linear-gradient(to right, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
}

.bg-blue,
.bg-red {
  position: absolute;
  top: -10%;
  width: 52vw;
  height: 120%;
  filter: blur(80rpx);
  opacity: 0.22;
}

.bg-blue {
  left: -10vw;
  background: #00d4ff;
}

.bg-red {
  right: -10vw;
  background: #ff3b77;
}

.main {
  position: relative;
  z-index: 2;
  height: 100vh;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 8rpx) 12rpx calc(env(safe-area-inset-bottom) + 8rpx);
  box-sizing: border-box;
  overflow: hidden;
}

.main-trio {
  overflow-y: auto;
}

.team {
  width: 31%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.main-trio .team {
  width: 30%;
}

.crown {
  margin-bottom: 2rpx;
  font-size: 40rpx;
  line-height: 1;
  animation: crownPulse 1.2s ease-in-out infinite;
}

.crown-a {
  text-shadow: 0 0 18rpx rgba(0, 212, 255, 0.85);
}

.crown-b {
  text-shadow: 0 0 18rpx rgba(255, 59, 119, 0.85);
}

.team-name {
  width: 100%;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 6rpx;
  letter-spacing: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.team-name-a {
  color: #80f2ff;
  text-shadow: 0 0 16rpx rgba(61, 231, 255, 0.7);
}

.team-name-b {
  color: #ff94bd;
  text-shadow: 0 0 16rpx rgba(255, 91, 138, 0.7);
}

.score-touch-zone {
  width: 100%;
  height: 52vh;
  min-height: 250rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(9, 16, 34, 0.35);
}

.score {
  font-size: 150rpx;
  font-weight: 900;
  line-height: 0.95;
}

.score-a {
  color: #3de7ff;
  text-shadow:
    0 0 10rpx rgba(61, 231, 255, 0.8),
    0 0 28rpx rgba(61, 231, 255, 0.6),
    0 0 46rpx rgba(61, 231, 255, 0.35);
  animation: neonBreathBlue 2.2s ease-in-out infinite;
}

.score-b {
  color: #ff5b8a;
  text-shadow:
    0 0 10rpx rgba(255, 91, 138, 0.8),
    0 0 28rpx rgba(255, 91, 138, 0.6),
    0 0 46rpx rgba(255, 91, 138, 0.35);
  animation: neonBreathRed 2.2s ease-in-out infinite;
}

.center-panel {
  /* width: 34%; */
  min-width: 260rpx;
  max-width: 360rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(11, 20, 42, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.main-trio .center-panel {
  width: 40%;
  min-width: 0;
  max-width: none;
  padding: 10rpx 8rpx;
  justify-content: flex-start;
  overflow-y: auto;
}

.timer-label {
  color: #99a5cb;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.timer-row {
  margin: 14rpx 0 18rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.mini {
  margin: 0;
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 12rpx;
  background: #1c2847;
  color: #b4c4ff;
  font-size: 34rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-shrink: 0;
}

.main-duel .mini {
  width: 50rpx;
  min-width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 26rpx;
  padding: 0;
}

.main-duel .timer-row {
  gap: 2rpx;
  justify-content: center;
}

.main-duel .timer {
  font-size: 64rpx;
}

.timer {
  font-size: 80rpx;
  line-height: 1;
  font-weight: 900;
  color: #ffd84f;
  text-shadow:
    0 0 8rpx rgba(255, 216, 79, 0.9),
    0 0 24rpx rgba(255, 216, 79, 0.5);
  animation: timerGlow 1.8s ease-in-out infinite;
}

.timer-critical {
  color: #ff5c5c;
  text-shadow:
    0 0 10rpx rgba(255, 92, 92, 0.9),
    0 0 30rpx rgba(255, 92, 92, 0.75),
    0 0 52rpx rgba(255, 92, 92, 0.5);
  animation: criticalPulse 0.9s ease-in-out infinite;
}

.center-ops {
  width: 100%;
  display: flex;
  gap: 10rpx;
}

.mt-8 {
  margin-top: 8rpx;
}

.round-label,
.waiting-label {
  color: #9db2e2;
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.main-trio .round-label,
.main-trio .waiting-label {
  font-size: 20rpx;
  margin-bottom: 4rpx;
}

.round-end,
.match-end,
.trio-undo
 {
  margin: 0;
  flex: 1;
  border-radius: 12rpx;
  height: 62rpx;
  line-height: 62rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  white-space: nowrap;
}

.main-trio .round-end,
.main-trio .match-end,
.main-trio .trio-undo {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 20rpx;
}

.main-trio .trio-actions {
  flex-direction: row;
  gap: 8rpx;
}

.main-trio .trio-actions .round-end,
.main-trio .trio-actions .match-end,
.main-trio .trio-actions .trio-undo {
  width: auto;
  flex: 1;
}

.round-end {
  color: #7ee7ff;
  background: #11283e;
  border: 1px solid #2f7db2;
}

.match-end {
  color: #ffd8a8;
  background: #3a2610;
  border: 1px solid #8f5f1b;
}

.start,
.reset,
.undo-btn {
  margin: 0;
  border-radius: 14rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
}

.start {
  flex: 1;
}

.play {
  color: #74f5ad;
  background: #103a2d;
  border: 1px solid #1f7d59;
}

.pause {
  color: #ffd086;
  background: #3a2a10;
  border: 1px solid #8f5f1b;
}

.reset {
  width: 156rpx;
  color: #c7d2fe;
  background: #1d2848;
  border: 1px solid #334155;
}

.undo-btn {
  width: 100%;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 22rpx;
  color: #f7e8ff;
  background: #3a1f46;
  border: 1px solid #7a46a4;
}

.trio-undo {
  color: #f7e8ff;
  background: #3a1f46;
  border: 1px solid #7a46a4;
}

.rules-wrap {
  width: 100%;
  padding: 8rpx;
  border-radius: 12rpx;
  background: rgba(18, 28, 56, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}

.rule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.rule-row + .rule-row {
  margin-top: 6rpx;
}

.rule-label {
  font-size: 17rpx;
  color: #bcd0ff;
}

.rule-value {
  font-size: 17rpx;
  color: #7ee7ff;
  background: #11283e;
  border: 1px solid #2f7db2;
  border-radius: 8rpx;
  padding: 4rpx 8rpx;
}

.theme-toggle {
  margin-bottom: 8rpx;
  border-radius: 12rpx;
  height: 54rpx;
  line-height: 54rpx;
  font-size: 22rpx;
  padding: 0 14rpx;
  color: #d7e3ff;
  background: #1a2645;
  border: 1px solid #334155;
}

.mode-toggle {
  width: 100%;
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.mode-btn {
  flex: 1;
  margin: 0;
  min-width: 0;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #b8c7eb;
  background: #131f3b;
  border: 1px solid #334155;
  padding: 0 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.main-trio .mode-btn {
  font-size: 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 6rpx;
}

.mode-active {
  color: #7ee7ff;
  border-color: #2f7db2;
  background: #11283e;
}

.time-over {
  margin-top: 12rpx;
  color: #ff6b6b;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 0 16rpx rgba(255, 92, 92, 0.8);
}

.result-wrap {
  position: relative;
  z-index: 2;
  height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: calc(env(safe-area-inset-top) + 16rpx) 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  box-sizing: border-box;
  overflow-y: auto;
}

.result-card {
  width: 100%;
  max-width: 680rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(145deg, rgba(7, 16, 40, 0.95), rgba(8, 13, 34, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow:
    0 0 0 1px rgba(255, 255, 255, 0.04) inset,
    0 20rpx 60rpx rgba(0, 0, 0, 0.45),
    -24rpx 0 56rpx rgba(0, 212, 255, 0.2),
    24rpx 0 56rpx rgba(255, 59, 119, 0.2);
  padding: 20rpx;
  box-sizing: border-box;
  animation: resultCardPulse 2.8s ease-in-out infinite;
}

.result-title {
  font-size: 42rpx;
  font-weight: 900;
  color: #ffd84f;
  margin-bottom: 14rpx;
  display: block;
  text-align: center;
  letter-spacing: 2rpx;
  text-shadow:
    0 0 10rpx rgba(255, 216, 79, 0.9),
    0 0 28rpx rgba(255, 216, 79, 0.5);
}

.rank-row {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 12rpx 10rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  gap: 10rpx;
}

.rank-row:nth-child(1) {
  background: linear-gradient(90deg, rgba(255, 215, 87, 0.15), rgba(255, 215, 87, 0.03));
  box-shadow: 0 0 20rpx rgba(255, 215, 87, 0.18);
}

.rank-row:nth-child(2) {
  background: linear-gradient(90deg, rgba(188, 204, 255, 0.12), rgba(188, 204, 255, 0.03));
}

.rank-row:nth-child(3) {
  background: linear-gradient(90deg, rgba(255, 167, 94, 0.12), rgba(255, 167, 94, 0.03));
}

.rank-tag,
.rank-name,
.rank-score {
  font-size: 24rpx;
}

.rank-tag {
  width: 170rpx;
  color: #9db2e2;
  text-align: left;
  font-weight: 700;
  line-height: 1.35;
  white-space: normal;
  word-break: break-word;
}

.rank-name {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  font-weight: 800;
  text-align: center;
  padding: 0 8rpx;
  line-height: 1.35;
  white-space: normal;
  word-break: break-word;
  letter-spacing: 1rpx;
}

.rank-score {
  width: 120rpx;
  flex-shrink: 0;
  font-weight: 900;
  text-align: right;
  animation: scoreFlicker 1.8s ease-in-out infinite;
}

.rank-row:nth-child(1) .rank-tag,
.rank-row:nth-child(1) .rank-name,
.rank-row:nth-child(1) .rank-score {
  color: #ffe07a;
  text-shadow:
    0 0 8rpx rgba(255, 224, 122, 0.9),
    0 0 22rpx rgba(255, 224, 122, 0.55);
}

.rank-row:nth-child(2) .rank-tag,
.rank-row:nth-child(2) .rank-name,
.rank-row:nth-child(2) .rank-score {
  color: #d6e5ff;
  text-shadow: 0 0 8rpx rgba(214, 229, 255, 0.6);
}

.rank-row:nth-child(3) .rank-tag,
.rank-row:nth-child(3) .rank-name,
.rank-row:nth-child(3) .rank-score {
  color: #ffc694;
  text-shadow: 0 0 8rpx rgba(255, 198, 148, 0.55);
}

.result-message {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #d7e3ff;
  background: rgba(17, 40, 62, 0.7);
  border: 1px solid rgba(126, 231, 255, 0.35);
  text-align: center;
}

.restart {
  margin-top: 16rpx;
  width: 100%;
  border-radius: 14rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 28rpx;
  color: #74f5ad;
  background: #103a2d;
  border: 1px solid #1f7d59;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
}

@keyframes neonBreathBlue {
  0%,
  100% {
    text-shadow:
      0 0 10rpx rgba(61, 231, 255, 0.8),
      0 0 28rpx rgba(61, 231, 255, 0.6),
      0 0 46rpx rgba(61, 231, 255, 0.35);
  }
  50% {
    text-shadow:
      0 0 14rpx rgba(61, 231, 255, 1),
      0 0 36rpx rgba(61, 231, 255, 0.9),
      0 0 66rpx rgba(61, 231, 255, 0.5);
  }
}

@keyframes neonBreathRed {
  0%,
  100% {
    text-shadow:
      0 0 10rpx rgba(255, 91, 138, 0.8),
      0 0 28rpx rgba(255, 91, 138, 0.6),
      0 0 46rpx rgba(255, 91, 138, 0.35);
  }
  50% {
    text-shadow:
      0 0 14rpx rgba(255, 91, 138, 1),
      0 0 36rpx rgba(255, 91, 138, 0.9),
      0 0 66rpx rgba(255, 91, 138, 0.5);
  }
}

@keyframes timerGlow {
  0%,
  100% {
    text-shadow:
      0 0 8rpx rgba(255, 216, 79, 0.9),
      0 0 24rpx rgba(255, 216, 79, 0.5);
  }
  50% {
    text-shadow:
      0 0 14rpx rgba(255, 216, 79, 1),
      0 0 34rpx rgba(255, 216, 79, 0.75);
  }
}

@keyframes criticalPulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.06);
    opacity: 0.82;
  }
}

@keyframes crownPulse {
  0%,
  100% {
    transform: translateY(0);
    opacity: 0.95;
  }
  50% {
    transform: translateY(-3rpx);
    opacity: 1;
  }
}

@keyframes resultCardPulse {
  0%,
  100% {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04) inset,
      0 20rpx 60rpx rgba(0, 0, 0, 0.45),
      -24rpx 0 56rpx rgba(0, 212, 255, 0.2),
      24rpx 0 56rpx rgba(255, 59, 119, 0.2);
  }
  50% {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.07) inset,
      0 24rpx 74rpx rgba(0, 0, 0, 0.5),
      -30rpx 0 70rpx rgba(0, 212, 255, 0.26),
      30rpx 0 70rpx rgba(255, 59, 119, 0.26);
  }
}

@keyframes scoreFlicker {
  0%,
  100% {
    opacity: 1;
    transform: translateX(0);
  }
  45% {
    opacity: 0.84;
    transform: translateX(-1rpx);
  }
  55% {
    opacity: 1;
    transform: translateX(1rpx);
  }
}

@media (max-height: 700px) {
  .result-card {
    padding: 16rpx;
  }

  .result-title {
    font-size: 38rpx;
    margin-bottom: 10rpx;
  }

  .rank-row {
    padding: 10rpx 8rpx;
  }

  .rank-tag,
  .rank-name,
  .rank-score {
    font-size: 22rpx;
  }

  .restart {
    margin-top: 12rpx;
    height: 62rpx;
    line-height: 62rpx;
    font-size: 26rpx;
  }
}

@media (max-height: 780px) {
  .main-trio .center-panel {
    padding: 8rpx 6rpx;
  }

  .main-trio .theme-toggle {
    height: 44rpx;
    line-height: 44rpx;
    font-size: 18rpx;
    margin-bottom: 4rpx;
  }

  .main-trio .mode-toggle {
    margin-bottom: 4rpx;
    gap: 6rpx;
  }

  .main-trio .mode-btn {
    height: 42rpx;
    line-height: 42rpx;
    font-size: 17rpx;
    padding: 0 4rpx;
  }

  .main-trio .timer-label {
    font-size: 17rpx;
    letter-spacing: 2rpx;
  }

  .main-trio .timer-row {
    margin: 6rpx 0 8rpx;
  }

  .main-trio .mini {
    width: 42rpx;
    height: 42rpx;
    line-height: 42rpx;
    font-size: 26rpx;
  }

  .main-trio .timer {
    font-size: 56rpx;
  }

  .main-trio .round-label,
  .main-trio .waiting-label {
    font-size: 18rpx;
    margin-bottom: 2rpx;
  }

  .main-trio .start,
  .main-trio .reset,
  .main-trio .round-end,
  .main-trio .match-end,
  .main-trio .trio-undo {
    height: 46rpx;
    line-height: 46rpx;
    font-size: 17rpx;
  }

  .main-trio .reset {
    width: 118rpx;
  }

  .main-trio .trio-actions {
    gap: 6rpx;
  }

  .main-trio .mt-8 {
    margin-top: 4rpx;
  }
}

@media (max-height: 430px) {
  .main {
    padding: 6rpx 8rpx;
  }

  .main-duel .mini {
    width: 52rpx;
    min-width: 52rpx;
    height: 52rpx;
    line-height: 52rpx;
    font-size: 30rpx;
  }

  .main-duel .timer {
    font-size: 60rpx;
  }

  .main-duel .timer-row {
    gap: 4rpx;
  }

  .team-name {
    font-size: 28rpx;
    margin-bottom: 4rpx;
  }

  .score-touch-zone {
    height: 46vh;
    min-height: 210rpx;
  }

  .score {
    font-size: 118rpx;
  }

  .center-panel {
    min-width: 224rpx;
    padding: 10rpx;
  }

  .timer {
    font-size: 64rpx;
  }

  .start,
  .reset {
    height: 58rpx;
    line-height: 58rpx;
    font-size: 22rpx;
  }

  .reset {
    width: 132rpx;
  }
}

.page.minimal {
  background: #000;
}

.page.minimal .bg-grid,
.page.minimal .bg-blue,
.page.minimal .bg-red {
  display: none;
}

.page.minimal .score-touch-zone,
.page.minimal .center-panel {
  background: #0a0a0a;
  border-color: #444;
}

.page.minimal .team-name-a,
.page.minimal .score-a {
  color: #79d7ff;
  text-shadow: none;
  animation: none;
}

.page.minimal .team-name-b,
.page.minimal .score-b {
  color: #ff8fb2;
  text-shadow: none;
  animation: none;
}

.page.minimal .timer {
  color: #fff;
  text-shadow: none;
  animation: none;
}

.page.minimal .timer-critical {
  color: #ff4d4d;
  text-shadow: none;
  animation: criticalPulse 0.9s ease-in-out infinite;
}
