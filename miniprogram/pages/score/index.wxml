<view class="page {{isMinimalTheme ? 'minimal' : ''}}">
  <view class="bg-grid"></view>
  <view class="bg-blue"></view>
  <view class="bg-red"></view>

  <view wx:if="{{phase === 'playing'}}" class="main {{matchMode === 'trio' ? 'main-trio' : 'main-duel'}}">
    <view class="team team-a">
      <text wx:if="{{matchMode === 'duel' ? isALeading : isLeftLeading}}" class="crown crown-a">👑</text>
      <input
        class="team-name team-name-a"
        value="{{matchMode === 'duel' ? teamA : leftPlayerName}}"
        bindinput="onTeamAInput"
        maxlength="20"
      />

      <view
        class="score-touch-zone"
        catchtouchstart="onScoreTouchStartA"
        catchtouchend="onScoreTouchEndA"
      >
        <text class="score score-a">{{matchMode === 'duel' ? scoreA : roundScoreLeft}}</text>
      </view>
    </view>

    <view class="center-panel">
      <button class="theme-toggle" bindtap="toggleTheme">{{isMinimalTheme ? '霓虹版' : '极简版'}}</button>

      <view class="mode-toggle">
        <button class="mode-btn {{matchMode === 'duel' ? 'mode-active' : ''}}" data-mode="duel" bindtap="switchMode">双人</button>
        <button class="mode-btn {{matchMode === 'trio' ? 'mode-active' : ''}}" data-mode="trio" bindtap="switchMode">三人轮转</button>
      </view>

      <text class="timer-label">MATCH TIME</text>

      <view class="timer-row">
        <button wx:if="{{!isRunning}}" class="mini" data-delta="-1" bindtap="adjustTime">-</button>
        <text class="timer {{isTimeCritical ? 'timer-critical' : ''}}">{{formattedTime}}</text>
        <button wx:if="{{!isRunning}}" class="mini" data-delta="1" bindtap="adjustTime">+</button>
      </view>

      <text wx:if="{{matchMode === 'trio'}}" class="round-label">第 {{roundIndex}} 局</text>
      <text wx:if="{{matchMode === 'trio'}}" class="waiting-label">待场：{{waitingPlayerName}}</text>

      <view class="center-ops">
        <button class="start {{isRunning ? 'pause' : 'play'}}" bindtap="toggleTimer">{{isRunning ? '暂停' : '开始'}}</button>
        <button class="reset" bindtap="resetTimer">重置时间</button>
      </view>

      <view wx:if="{{matchMode === 'trio'}}" class="center-ops trio-actions mt-8">
        <button class="round-end" bindtap="finishRound">结束本局</button>
        <button class="match-end" bindtap="endMatch">结束比赛</button>
        <button class="trio-undo" bindtap="undoLastAction">撤销上一步</button>
      </view>

      <view wx:if="{{matchMode === 'trio'}}" class="rules-wrap mt-8">
        <view class="rule-row">
          <text class="rule-label">平分结束策略</text>
          <picker mode="selector" range="{{['不允许结束','左侧判负','右侧判负']}}" value="{{trioRuleTiePolicy === 'block' ? 0 : (trioRuleTiePolicy === 'leftLose' ? 1 : 2)}}" bindchange="onTiePolicyChange">
            <view class="rule-value">{{trioRuleTiePolicy === 'block' ? '不允许结束' : (trioRuleTiePolicy === 'leftLose' ? '左侧判负' : '右侧判负')}}</view>
          </picker>
        </view>
        <view class="rule-row">
          <text class="rule-label">结束比赛策略</text>
          <picker mode="selector" range="{{['必须先结束本局','自动结算当前局']}}" value="{{trioRuleEndMatchPolicy === 'block' ? 0 : 1}}" bindchange="onEndMatchPolicyChange">
            <view class="rule-value">{{trioRuleEndMatchPolicy === 'block' ? '必须先结束本局' : '自动结算当前局'}}</view>
          </picker>
        </view>
      </view>

      <text wx:if="{{timeLeft === 0}}" class="time-over">TIME OVER</text>
    </view>

    <view class="team team-b">
      <text wx:if="{{matchMode === 'duel' ? isBLeading : isRightLeading}}" class="crown crown-b">👑</text>
      <input
        class="team-name team-name-b"
        value="{{matchMode === 'duel' ? teamB : rightPlayerName}}"
        bindinput="onTeamBInput"
        maxlength="20"
      />

      <view
        class="score-touch-zone"
        catchtouchstart="onScoreTouchStartB"
        catchtouchend="onScoreTouchEndB"
      >
        <text class="score score-b">{{matchMode === 'duel' ? scoreB : roundScoreRight}}</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{phase === 'finished'}}" class="result-wrap">
    <view class="result-card">
      <text class="result-title">比赛结果</text>
      <view class="result-list">
        <view wx:for="{{rankings}}" wx:key="id" class="rank-row">
          <text class="rank-tag">{{item.tag}}</text>
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-score">{{item.totalScore}} 分</text>
        </view>
      </view>
      <button class="restart" bindtap="restartMatch">再来一场</button>
    </view>
  </view>
</view>