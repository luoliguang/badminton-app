<view class="page {{isMinimalTheme ? 'minimal' : ''}}">
  <view class="bg-grid"></view>
  <view class="bg-blue"></view>
  <view class="bg-red"></view>

  <view class="main">
    <view class="team team-a">
      <text wx:if="{{isALeading}}" class="crown crown-a">👑</text>
      <input class="team-name team-name-a" value="{{teamA}}" bindinput="onTeamAInput" maxlength="20" />

      <view
        class="score-touch-zone"
        catchtouchstart="onScoreTouchStartA"
        catchtouchend="onScoreTouchEndA"
      >
        <text class="score score-a">{{scoreA}}</text>
      </view>
    </view>

    <view class="center-panel">
      <button class="theme-toggle" bindtap="toggleTheme">{{isMinimalTheme ? '霓虹版' : '极简版'}}</button>
      <text class="timer-label">MATCH TIME</text>

      <view class="timer-row">
        <button wx:if="{{!isRunning}}" class="mini" data-delta="-1" bindtap="adjustTime">-</button>
        <text class="timer {{isTimeCritical ? 'timer-critical' : ''}}">{{formattedTime}}</text>
        <button wx:if="{{!isRunning}}" class="mini" data-delta="1" bindtap="adjustTime">+</button>
      </view>

      <view class="center-ops">
        <button class="start {{isRunning ? 'pause' : 'play'}}" bindtap="toggleTimer">{{isRunning ? '暂停' : '开始'}}</button>
        <button class="reset" bindtap="resetTimer">重置时间</button>
      </view>

      <text wx:if="{{timeLeft === 0}}" class="time-over">TIME OVER</text>
    </view>

    <view class="team team-b">
      <text wx:if="{{isBLeading}}" class="crown crown-b">👑</text>
      <input class="team-name team-name-b" value="{{teamB}}" bindinput="onTeamBInput" maxlength="20" />

      <view
        class="score-touch-zone"
        catchtouchstart="onScoreTouchStartB"
        catchtouchend="onScoreTouchEndB"
      >
        <text class="score score-b">{{scoreB}}</text>
      </view>
    </view>
  </view>
</view>
