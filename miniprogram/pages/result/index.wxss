.page { min-height:100vh; background:#f7faf9; padding:16px 24px 24px; }
.celebrate-card, .summary-card, .rank-card, .reward-card, .mvp-card, .mini-card { background:#fff; border:2px solid #011b3e; }
.celebrate-card { padding:20px; text-align:center; }
.celebrate-icon { font-size:28px; display:block; }
.celebrate-title { font-size:22px; font-weight:600; display:block; color:#011b3e; margin-top:8px; }
.celebrate-subtitle, .celebrate-meta { display:block; font-size:12px; color:#4a5f85; margin-top:6px; }
.summary-grid { display:flex; gap:12px; margin-top:16px; }
.summary-card { flex:1; padding:14px; }
.summary-label, .section-title, .reward-key, .mini-label, .mvp-label { font-size:12px; color:#4a5f85; }
.summary-value, .summary-stars { font-size:22px; font-weight:600; color:#011b3e; display:block; margin-top:6px; }
.section-head { margin-top:18px; margin-bottom:10px; }
.rank-list, .reward-list, .bento-grid { display:flex; flex-direction:column; gap:12px; }
.rank-card { display:flex; align-items:center; justify-content:space-between; padding:14px; }
.rank-tag { font-size:12px; color:#ae3200; }
.rank-circle { width:36px; height:36px; border-radius:9999px; border:2px solid #011b3e; display:flex; align-items:center; justify-content:center; font-weight:600; }
.rank-center { flex:1; margin-left:12px; }
.rank-name { display:block; font-size:16px; font-weight:600; color:#011b3e; }
.rank-team { display:block; font-size:12px; color:#4a5f85; margin-top:4px; }
.rank-score { text-align:right; }
.score-num { font-size:18px; font-weight:600; color:#011b3e; }
.score-unit { font-size:12px; color:#4a5f85; }
.reward-card { display:flex; gap:12px; align-items:flex-start; padding:14px; }
.reward-value { display:block; font-size:14px; color:#011b3e; margin-top:4px; }
.mvp-card, .mini-card { padding:14px; }
.mvp-row { display:flex; align-items:center; justify-content:space-between; margin-top:8px; }
.mvp-name, .mini-value { font-size:18px; font-weight:600; color:#011b3e; }
.home-btn { margin-top:18px; height:56px; background:#ccff00; border:2px solid #011b3e; color:#011b3e; font-weight:600; }
.sets-row { display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin-top:10px; }
.set-chip { background:#011b3e; padding:4px 12px; display:flex; flex-direction:column; align-items:center; gap:2px; }
.set-chip-label { font-size:10px; color:#abd600; }
.set-chip-score { font-size:14px; font-weight:700; color:#ccff00; }
.reward-key { display:block; font-size:13px; font-weight:600; color:#011b3e; }
