.page {
  min-height: 100vh;
  background: #f7faf9;
  padding-bottom: 24px;
}
.topbar { height: 64px; padding: 0 24px; display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #011b3e; background:#fff; }
.topbar-title { font-size:20px; font-weight:600; color:#011b3e; }
.mode-card, .create-panel, .join-card { margin:16px 24px 0; padding:20px; background:#fff; border:2px solid #011b3e; }
.mode-label, .panel-title, .join-label { display:block; font-size:12px; color:#4a5f85; margin-bottom:8px; }
.mode-value { font-size:18px; font-weight:600; color:#011b3e; }
.type-row { display:flex; gap:10px; flex-wrap:wrap; margin: 12px 0; }
.type-item { padding:10px 14px; border:2px solid #011b3e; background:#fff; }
.type-item.active { background:#ccff00; }
.setting-item { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-top:1px solid #e5e7eb; }
.setting-label { font-size:12px; color:#4a5f85; }
.setting-value { font-size:16px; color:#011b3e; font-weight:600; }
.switch-row { gap:12px; }
.create-btn, .join-btn, .start-btn { margin-top:16px; height:56px; background:#ccff00; border:2px solid #011b3e; color:#011b3e; font-weight:600; }
.join-row { display:flex; gap:10px; }
.join-input { flex:1; border:2px solid #011b3e; padding:0 12px; height:48px; background:#fff; }
.players-head { margin:16px 24px 0; display:flex; justify-content:space-between; align-items:center; }
.section-title { font-size:18px; font-weight:600; color:#011b3e; }
.players-count { font-size:12px; color:#4a5f85; }
.players-list { margin:12px 24px 0; display:flex; flex-direction:column; gap:12px; }
.player-card { padding:14px; background:#fff; border:2px solid #011b3e; display:flex; align-items:center; justify-content:space-between; }
.player-card.empty { opacity:.7; background:#f8fafc; }
.avatar { width:40px; height:40px; border-radius:9999px; background:#e2e8f0; }
.text-avatar { background:#ccff00; border:2px solid #011b3e; display:flex; align-items:center; justify-content:center; }
.avatar-text { font-size:16px; font-weight:700; color:#011b3e; line-height:1; }
.player-info { flex:1; margin-left:12px; }
.player-name { display:block; font-size:16px; color:#011b3e; font-weight:600; }
.player-meta { display:block; font-size:12px; color:#4a5f85; margin-top:4px; }
.footer-wrap { margin:16px 24px 0; display:flex; flex-direction:column; gap:10px; }
.ready-text { color:#4a5f85; font-size:12px; text-align:center; }
.dissolve-btn { height:44px; background:#fff; border:2px solid #ae3200; color:#ae3200; font-size:14px; }
.kick-btn { padding:4px 12px; background:#ae3200; color:#fff; font-size:12px; white-space:nowrap; }
.room-code-card { margin:16px 24px 0; padding:16px 20px; background:#ccff00; border:2px solid #011b3e; }
.room-code-label { display:block; font-size:11px; color:#4a5f85; margin-bottom:10px; }
.room-code-row { display:flex; align-items:center; justify-content:space-between; }
.room-code-value { font-size:30px; font-weight:700; color:#011b3e; letter-spacing:4px; }
.copy-btn { padding:8px 18px; background:#011b3e; color:#ccff00; font-size:13px; font-weight:600; }
