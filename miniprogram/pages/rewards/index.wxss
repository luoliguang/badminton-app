.page { min-height:100vh; background:#f7faf9; padding-bottom:32px; }
.topbar { padding:20px 24px 14px; background:#011b3e; }
.topbar-title { display:block; font-size:22px; font-weight:700; color:#ccff00; }
.topbar-sub { display:block; font-size:12px; color:#abd600; margin-top:4px; }

.empty-state { padding:60px 24px; display:flex; flex-direction:column; align-items:center; gap:12px; }
.empty-icon { font-size:48px; }
.empty-text { font-size:16px; color:#011b3e; font-weight:600; }
.empty-hint { font-size:12px; color:#4a5f85; }

.match-list { padding:16px 16px 0; display:flex; flex-direction:column; gap:16px; }

.match-block { border:2px solid #011b3e; background:#fff; overflow:hidden; }

.match-header { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; }
.match-header.win { background:#ccff00; }
.match-header.lose { background:#f1f5f9; }

.match-header-left { display:flex; align-items:center; gap:12px; }
.match-result-badge { width:32px; height:32px; border-radius:9999px; background:#011b3e; color:#ccff00; font-size:14px; font-weight:700; display:flex; align-items:center; justify-content:center; }
.match-meta { display:flex; flex-direction:column; gap:2px; }
.match-type { font-size:14px; font-weight:600; color:#011b3e; }
.match-date { font-size:11px; color:#4a5f85; }

.match-score-col { text-align:right; }
.set-score { display:block; font-size:20px; font-weight:700; color:#011b3e; }
.set-detail { display:block; font-size:11px; color:#4a5f85; margin-top:2px; }

.awards-list { border-top:1px solid #e5e7eb; padding:12px 16px; display:flex; flex-direction:column; gap:8px; }
.award-row { display:flex; align-items:baseline; gap:8px; }
.award-key { font-size:13px; font-weight:600; color:#011b3e; white-space:nowrap; }
.award-val { font-size:13px; color:#4a5f85; flex:1; }

.no-awards { padding:12px 16px; font-size:12px; color:#4a5f85; border-top:1px solid #e5e7eb; }
