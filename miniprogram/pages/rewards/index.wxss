.page { min-height:100vh; background:#f7faf9; padding-bottom:32px; }
.topbar { padding:20px 24px 14px; background:#011b3e; }
.topbar-title { display:block; font-size:22px; font-weight:700; color:#ccff00; }
.topbar-sub { display:block; font-size:12px; color:#abd600; margin-top:4px; }
.hero-panel { margin:16px 16px 0; padding:18px 16px; background:#ffffff; border:2px solid #011b3e; box-shadow:0 1px 0 rgba(1,27,62,0.08); }
.hero-kicker { display:block; font-size:10px; color:#4a5f85; letter-spacing:1.2px; }
.hero-title { display:block; margin-top:6px; font-size:18px; font-weight:700; color:#011b3e; }
.hero-desc { display:block; margin-top:6px; font-size:12px; color:#4a5f85; line-height:1.6; }
.empty-state { padding:24px 16px 0; display:flex; justify-content:center; }
.empty-card { width:100%; padding:28px 16px; background:#ffffff; border:2px solid #011b3e; display:flex; flex-direction:column; align-items:center; gap:10px; text-align:center; }
.empty-icon { font-size:40px; line-height:1; }
.empty-text { font-size:16px; color:#011b3e; font-weight:700; }
.empty-hint { font-size:12px; color:#4a5f85; line-height:1.6; }
.match-list { padding:16px 16px 0; display:flex; flex-direction:column; gap:16px; }
.match-block { border:2px solid #011b3e; background:#fff; overflow:hidden; }
.match-header { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; }
.match-header.win { background:#ccff00; }
.match-header.lose { background:#f1f5f9; }
.match-header-left { display:flex; align-items:center; gap:12px; min-width:0; }
.match-result-badge { width:32px; height:32px; border-radius:9999px; background:#011b3e; color:#fff; font-size:14px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.badge-win { background:#011b3e; color:#ccff00; }
.badge-lose { background:#4a5f85; color:#ffffff; }
.match-meta { display:flex; flex-direction:column; gap:2px; min-width:0; }
.match-type { font-size:14px; font-weight:700; color:#011b3e; }
.match-date { font-size:11px; color:#4a5f85; }
.match-score-col { text-align:right; flex-shrink:0; }
.set-score { display:block; font-size:20px; font-weight:700; color:#011b3e; }
.set-detail { display:block; font-size:11px; color:#4a5f85; margin-top:2px; }
.awards-list { border-top:1px solid #e5e7eb; padding:12px 16px; display:flex; flex-direction:column; gap:10px; }
.award-row { display:flex; align-items:flex-start; gap:10px; }
.award-icon { width:22px; height:22px; border-radius:9999px; background:#ccff00; border:1px solid #011b3e; flex-shrink:0; margin-top:2px; }
.award-content { flex:1; min-width:0; }
.award-key { display:block; font-size:13px; font-weight:700; color:#011b3e; }
.award-val { display:block; margin-top:4px; font-size:13px; color:#4a5f85; line-height:1.5; }
.no-awards { padding:14px 16px; font-size:12px; color:#4a5f85; border-top:1px solid #e5e7eb; }
