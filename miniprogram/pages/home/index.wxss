.page {
  min-height: 100vh;
  background: #f7faf9;
  padding: 0 0 24px;
  color: #011b3e;
  font-variant-numeric: tabular-nums;
}

.topbar {
  height: 64px;
  padding: 0 24px;
  background: #ffffff;
  border-bottom: 2px solid #011b3e;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #011b3e;
}

.brand-logo {
  font-size: 24px;
  line-height: 1;
}

.brand-text {
  font-size: 20px;
  font-weight: 600;
  letter-spacing: 0.4px;
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.topbar-icon {
  font-size: 18px;
  color: #011b3e;
}

.avatar-placeholder {
  width: 32px;
  height: 32px;
  border-radius: 9999px;
  background: #ccff00;
  border: 2px solid #011b3e;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-initial {
  font-size: 14px;
  font-weight: 700;
  color: #011b3e;
  line-height: 1;
}

.hero-card {
  position: relative;
  margin: 24px 24px 0;
  padding: 26px;
  background: #011b3e;
  border: 2px solid #011b3e;
  overflow: hidden;
}

.hero-decoration {
  position: absolute;
  right: -20px;
  bottom: -18px;
  width: 128px;
  height: 128px;
  border-radius: 9999px;
  background: rgba(163, 230, 53, 0.1);
}

.hero-label {
  position: relative;
  z-index: 1;
  display: block;
  color: #abd600;
  font-size: 12px;
  letter-spacing: 1.2px;
}

.hero-value-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  gap: 2px;
  margin-top: 8px;
}

.hero-value {
  color: #ccff00;
  font-size: 80px;
  font-weight: 400;
  line-height: 1;
}

.hero-percent {
  color: #ccff00;
  font-size: 24px;
  line-height: 1;
  padding-bottom: 10px;
}

.hero-footer {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10px;
}

.hero-level {
  color: #ffffff;
  font-size: 12px;
}

.hero-trophy {
  font-size: 16px;
}

.stat-row {
  display: flex;
  gap: 16px;
  margin: 16px 24px 0;
}

.stat-card {
  flex: 1;
  min-width: 0;
  padding: 18px 16px;
  border: 2px solid #011b3e;
  font-variant-numeric: tabular-nums;
}

.total-card {
  background: #ffffff;
}

.streak-card {
  background: #ccff00;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: #4a5f85;
}

.streak-label {
  color: #5b7300;
}

.stat-value {
  display: block;
  margin-top: 8px;
  font-size: 32px;
  line-height: 1;
  color: #011b3e;
}

.streak-value-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.streak-icon {
  font-size: 16px;
  margin-top: 6px;
}

.heatmap-card {
  margin: 16px 24px 0;
  padding: 26px;
  background: #ffffff;
  border: 2px solid #011b3e;
}

.heatmap-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16px;
}

.section-title {
  font-size: 18px;
  color: #011b3e;
  font-weight: 600;
}

.section-meta {
  font-size: 10px;
  color: #4a5f85;
}

.heatmap-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  width: 100%;
}

.heatmap-cell {
  width: 12px;
  height: 12px;
  border-radius: 2px;
}

.heatmap-cell.empty { background: #f1f5f9; }
.heatmap-cell.normal { background: #abd600; }
.heatmap-cell.strong { background: #506600; }

.heatmap-legend {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 14px;
}

.legend-text {
  font-size: 10px;
  color: #4a5f85;
}

.legend-bars {
  display: flex;
  gap: 4px;
}

.legend-bar {
  width: 12px;
  height: 12px;
  border-radius: 2px;
}

.legend-bar.empty { background: #f1f5f9; }
.legend-bar.normal { background: #abd600; }
.legend-bar.strong { background: #506600; }

.action-wrap {
  margin: 16px 24px 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.action-btn {
  height: 64px;
  border: 2px solid #011b3e;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  line-height: 1;
}

.action-btn::after { display: none; }

.create-btn {
  background: #ccff00;
  color: #011b3e;
}

.resume-btn {
  background: #011b3e;
  color: #ccff00;
}

.join-btn {
  background: #ae3200;
  color: #ffffff;
}

.scan-btn {
  background: #ffffff;
  height: 56px;
  border-style: dashed;
  justify-content: center;
  gap: 8px;
}

.action-icon,
.action-arrow,
.scan-icon {
  font-size: 18px;
  line-height: 1;
}

.action-text {
  font-size: 18px;
  color: #011b3e;
}

.join-text {
  color: #ffffff;
}

.scan-text {
  font-size: 12px;
  color: #011b3e;
}

.recent-head {
  margin: 22px 24px 0;
  padding-bottom: 8px;
  border-bottom: 2px solid #011b3e;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.view-all {
  font-size: 10px;
  color: #506600;
  text-decoration: underline;
}

.match-list {
  margin: 14px 24px 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.match-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 14px 14px 16px;
  background: #ffffff;
  border-left: 8px solid #cbd5e1;
  box-shadow: 0 1px 0 rgba(1, 27, 62, 0.08);
}

.match-card.win-card { border-left-color: #a3e635; }
.match-card.lose-card { opacity: 0.8; }

.match-left {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
}

.match-avatar {
  width: 48px;
  height: 48px;
  border-radius: 9999px;
  background: #e2e8f0;
  flex-shrink: 0;
}

.match-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.match-title {
  font-size: 16px;
  color: #011b3e;
  font-weight: 600;
}

.match-time {
  margin-top: 4px;
  font-size: 10px;
  color: #4a5f85;
}

.match-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}

.match-result {
  font-size: 12px;
  font-weight: 700;
}

.match-result.win { color: #a3e635; }
.match-result.lose { color: #cbd5e1; }

.match-score {
  font-size: 12px;
  color: #011b3e;
}
