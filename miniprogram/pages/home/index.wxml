<view class="page">
  <view class="topbar">
    <view class="brand">
      <text class="brand-logo">🏸</text>
      <text class="brand-text">SHUTTLE SMASH</text>
    </view>
    <view class="topbar-actions">
      <view class="avatar-shell" bindtap="onAvatarTap">
        <image wx:if="{{userAvatarUrl}}" class="avatar-image" src="{{userAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-initial">{{userInitial}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="hero-card">
    <view class="hero-decoration"></view>
    <text class="hero-label">当前胜率</text>
    <view class="hero-value-row">
      <text class="hero-value">{{profile.winRate}}</text>
      <text class="hero-percent">%</text>
    </view>
    <view class="hero-footer">
      <text class="hero-level">{{profile.rank}}</text>
      <text class="hero-trophy">🏆</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-card total-card">
      <text class="stat-label">总场次</text>
      <text class="stat-value">{{profile.totalGames}}</text>
    </view>
    <view class="stat-card streak-card">
      <text class="stat-label streak-label">连胜</text>
      <view class="streak-value-row">
        <text class="stat-value streak-value">{{profile.currentStreak}}</text>
        <text class="streak-icon">🔥</text>
      </view>
    </view>
  </view>

  <view class="action-wrap">
    <button class="action-btn {{hasActiveRoom ? 'resume-btn' : 'create-btn'}}" bindtap="onCreateRoom">
      <view class="action-icon create-icon"></view>
      <text class="action-text {{hasActiveRoom ? 'action-text-light' : ''}}">{{hasActiveRoom ? '返回我的房间' : '创建比赛房间'}}</text>
      <text class="action-arrow">›</text>
    </button>
    <button class="action-btn join-btn" bindtap="onJoinByCode">
      <view class="action-icon join-icon"></view>
      <text class="action-text join-text">口令加入</text>
      <text class="action-arrow">›</text>
    </button>
    <button class="action-btn scan-btn" bindtap="onScanJoin">
      <view class="scan-icon"></view>
      <text class="scan-text">扫码加入</text>
    </button>
  </view>

  <view class="heatmap-card">
    <view class="heatmap-head">
      <text class="section-title">运动热力图</text>
      <text class="section-meta">最近 6 个月</text>
    </view>
    <view class="heatmap-grid">
      <view
        wx:for="{{heatmap}}"
        wx:key="index"
        class="heatmap-cell {{item.count === 0 ? 'empty' : (item.count >= 3 ? 'strong' : 'normal')}}"
        bindtap="onHeatmapTap"
        data-date="{{item.date}}"
        data-count="{{item.count || 0}}"
      ></view>
    </view>
    <view class="heatmap-legend">
      <text class="legend-text">少</text>
      <view class="legend-bars">
        <view class="legend-bar empty"></view>
        <view class="legend-bar normal"></view>
        <view class="legend-bar strong"></view>
      </view>
      <text class="legend-text">多</text>
    </view>
  </view>

  <view class="recent-head">
    <text class="section-title">最近动态</text>
    <text class="view-all">查看全部</text>
  </view>

  <view class="match-list">
    <view class="match-card {{item.result === 'win' ? 'win-card' : 'lose-card'}}" wx:for="{{recentMatches}}" wx:key="index">
      <view class="match-left">
        <view class="match-avatar"></view>
        <view class="match-meta">
          <text class="match-title">{{item.title}}</text>
          <text class="match-time">{{item.time}}</text>
        </view>
      </view>
      <view class="match-right">
        <text class="match-result {{item.result}}">{{item.result === 'win' ? '胜' : '负'}}</text>
        <text class="match-score">21-18, 21-15</text>
      </view>
    </view>
  </view>
</view>
