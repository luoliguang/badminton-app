<view class="page">
  <view class="hero-card">
    <text class="hero-label">总胜率</text>
    <view class="hero-value-row">
      <text class="hero-value">{{winRate.replace('%','')}}</text>
      <text class="hero-percent">%</text>
    </view>
    <view class="hero-footer">
      <text class="hero-level">总场次 {{totalGames}}</text>
      <text class="hero-trophy">📊</text>
    </view>
  </view>

  <view class="tab-row">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="onTabTap">全部</view>
    <view class="tab-item {{activeTab === 'singles' ? 'active' : ''}}" data-tab="singles" bindtap="onTabTap">单打</view>
    <view class="tab-item {{activeTab === 'doubles' ? 'active' : ''}}" data-tab="doubles" bindtap="onTabTap">双打</view>
  </view>

  <view class="list-wrap">
    <view class="history-card" wx:for="{{filteredMatches}}" wx:key="index">
      <view class="history-left">
        <text class="history-title">{{item.opponent}}</text>
        <text class="history-sub">{{item.time}}</text>
      </view>
      <view class="history-right">
        <text class="history-score">{{item.score}}</text>
        <text class="history-result {{item.result}}">{{item.result === 'win' ? '胜' : '负'}}</text>
      </view>
    </view>
  </view>
</view>
